{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npx prisma generate --schema=../../packages/prisma/schema.prisma && npx tsc"
  },
  "deploy": {
    "startCommand": "npx prisma migrate deploy --schema=../../packages/prisma/schema.prisma && node dist/server.js",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 60,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
